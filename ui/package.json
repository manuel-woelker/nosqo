{
  "name": "@nosqo/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:run && pnpm run build"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.122.0",
    "immer": "^11.1.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript/native-preview": "^7.0.0-dev.20260322.1",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/vite-plugin": "^5.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.8.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.18.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3"
}
